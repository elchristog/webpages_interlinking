{
  "presets": [
    {
      "id": "ui-preset--emerald",
      "name": "Emerald Professional",
      "type": "dark",
      "description": "Estilo profesional en tonos verde esmeralda/teal. Fondo oscuro, texto luz. Ideal para confianza."
    },
    {
      "id": "ui-preset--midnight",
      "name": "Midnight Luxury",
      "type": "dark",
      "description": "Estilo lujo/premium en azul medianoche. Fondo muy oscuro, texto blanco. Ideal para exclusividad."
    },
    {
      "id": "ui-preset--sunset",
      "name": "Sunset Impact",
      "type": "light",
      "description": "Estilo de alto impacto en naranja/ámbar. Fondo cálido, texto oscuro (Zinc-950). Ideal para CTAs y energía."
    },
    {
      "id": "ui-preset--professional",
      "name": "Slate Professional",
      "type": "dark",
      "description": "Estilo corporativo elegante en gris pizarra/azul acero. Fondo oscuro, texto blanco."
    }
  ],
  "heroes": [
    {
      "id": "ui-hero-romuald",
      "name": "Hero Romuald (Personal Brand)",
      "allowed_presets": ["ui-preset--emerald", "ui-preset--midnight", "ui-preset--professional"],
      "prompt": "HERO PREMIUM ROMUALD (ui-hero-romuald): DISEÑO ESTÁNDAR OBLIGATORIO PARA 2026. Úsalo SIEMPRE en el inicio del artículo o home.\n<div class=\"ui-hero-romuald {preset}\">\n  <div class=\"hero-content\">\n    <span class=\"badge\">NUEVO MÉTODO 2026</span>\n    <h1>Título de Impacto</h1>\n    <p class=\"subtitle\">Subtítulo que resuelva el dolor principal del usuario...</p>\n    <p class=\"cta-text\">¿Deseas dar el siguiente paso hoy?</p>\n    <a href=\"URL\" class=\"btn\">🚀 Sí, Cuéntame Más</a>\n  </div>\n  <div class=\"hero-image\">\n    <img src=\"URL_IMAGEN_PERSONA\" alt=\"Persona de confianza\">\n  </div>\n</div>"
    },
    {
      "id": "ui-hero-performance",
      "name": "Hero Performance (Centered)",
      "allowed_presets": ["ui-preset--emerald", "ui-preset--midnight", "ui-preset--professional"],
      "prompt": "HERO PERFORMANCE (ui-hero-performance): Diseño centrado para destacar RESULTADOS y AUTORIDAD. Úsalo como alternativa al Romuald.\n<div class=\"ui-hero-performance {preset}\">\n  <div class=\"hero-content\">\n    <span class=\"hero-badge\">RESULTADOS GARANTIZADOS</span>\n    <h1>Título con <span class=\"ui-highlight-alt\">Highlight de Impacto</span></h1>\n    <p class=\"hero-subtitle\">Subtítulo que detalle el beneficio principal en 2 líneas...</p>\n    <a href=\"URL\" class=\"btn\">🚀 BOTÓN DE ACCIÓN</a>\n  </div>\n</div>"
    },
    {
      "id": "ui-hero-agency",
      "name": "Hero Agency (BigSEO style)",
      "allowed_presets": ["ui-preset--midnight", "ui-preset--emerald", "ui-preset--professional"],
      "prompt": "HERO AGENCY (ui-hero-agency): Estilo corporativo de alto impacto con logos de confianza al pie. Úsalo para landing pages transaccionales.\n<div class=\"ui-hero-agency {preset}\">\n  <div class=\"hero-content\">\n    <h1>Título <span class=\"ui-highlight\">Impactante</span></h1>\n    <p class=\"subtitle\">Subtítulo que detalle el beneficio principal en 2-3 líneas...</p>\n    <div class=\"hero-cta\"><a href=\"URL\" class=\"btn-agency\">BOTÓN ACCIÓN</a></div>\n    <div class=\"trust-bar\">\n      <img src=\"https://via.placeholder.com/150x50?text=LOGO1\" alt=\"Trust 1\" class=\"trust-logo\">\n      <img src=\"https://via.placeholder.com/150x50?text=LOGO2\" alt=\"Trust 2\" class=\"trust-logo\">\n      <img src=\"https://via.placeholder.com/150x50?text=LOGO3\" alt=\"Trust 3\" class=\"trust-logo\">\n    </div>\n  </div>\n</div>"
    }
  ],
  "sections": [
    {
      "id": "ui-section-dark",
      "allowed_presets": ["ui-preset--emerald", "ui-preset--midnight", "ui-preset--professional"],
      "prompt": "SECCIÓN OSCURA (ui-section-dark): <div class=\"ui-section-dark {preset}\"><div class=\"container\">...contenido...</div></div>"
    },
    {
        "id": "ui-section-accent",
        "allowed_presets": ["ui-preset--sunset"],
        "prompt": "SECCIÓN ACENTO (ui-section-accent): <div class=\"ui-section-accent {preset}\"><div class=\"container\">...contenido...</div></div>"
    },
    {
      "id": "ui-section-sand",
      "allowed_presets": [],
      "prompt": "SECCIÓN ARENA (ui-section-sand): <div class=\"ui-section-sand\"><div class=\"container\">...contenido...</div></div>"
    },
    {
        "id": "ui-grid-3",
        "allowed_presets": ["ui-preset--emerald", "ui-preset--midnight", "ui-preset--professional", "ui-preset--sunset"],
        "prompt": "GRID MULTI-COLUMNA (ui-grid-3): <div class=\"ui-grid-3 {preset}\">...contenido con ui-card...</div>"
    }
  ],
  "utilities": [
    {
      "id": "ui-card",
      "prompt": "TARJETA PREMIUM (ui-card): <div class=\"ui-card\"><h3>Título</h3><p>Contenido...</p></div>"
    },
    {
      "id": "ui-callout-tip",
      "prompt": "RECUADRO TIP (ui-callout-tip): <div class=\"ui-callout ui-callout-tip\"><span>💡</span><p>Consejo experto...</p></div>"
    },
    {
      "id": "ui-step-list",
      "prompt": "LISTA DE PASOS (ui-step-list): <div class=\"ui-step-list\"><div class=\"ui-step-item\"><h4>Paso 1</h4><p>Descripción...</p></div></div>"
    },
    {
      "id": "ui-stats",
      "prompt": "ESTADÍSTICAS (ui-stats): <div class=\"ui-stats\"><div class=\"ui-stat-item\"><span class=\"ui-stat-value\">97%</span><span class=\"ui-stat-label\">Éxito</span></div></div>"
    },
    {
        "id": "ui-check-list",
        "prompt": "LISTA DE VERIFICACIÓN (ui-check-list): <div class=\"ui-check-list\"><div class=\"ui-check-item\"><span>✅</span><p>Beneficio...</p></div></div>"
    }
  ]
}
