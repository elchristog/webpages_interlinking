---
import LayoutA from '../../layouts/LayoutA.astro';
import LayoutB from '../../layouts/LayoutB.astro';
import LayoutC from '../../layouts/LayoutC.astro';
import LayoutD from '../../layouts/LayoutD.astro';
import LayoutE from '../../layouts/LayoutE.astro';
import LayoutF from '../../layouts/LayoutF.astro';
import LayoutG from '../../layouts/LayoutG.astro';
import config from '../../data/config_inyectada.json';
import Text from '../../components/fundations/elements/Text.astro';
import Wrapper from '../../components/fundations/containers/Wrapper.astro';

const { frontmatter, Content } = Astro.props;

export async function getStaticPaths() {
  const articulos = Object.values(import.meta.glob('../../content/articulos/*.md', { eager: true }));
  
  return articulos.map(articulo => ({
    params: { slug: articulo.frontmatter.slug },
    props: { ...articulo },
  }));
}

// Logic to pick layout
let SelectedLayout = LayoutA;
if (config.layout === 'LayoutB') {
  SelectedLayout = LayoutB;
} else if (config.layout === 'LayoutC') {
  SelectedLayout = LayoutC;
} else if (config.layout === 'LayoutD') {
  SelectedLayout = LayoutD;
} else if (config.layout === 'LayoutE') {
  SelectedLayout = LayoutE;
} else if (config.layout === 'LayoutF') {
  SelectedLayout = LayoutF;
} else if (config.layout === 'LayoutG') {
  SelectedLayout = LayoutG;
}
---

<SelectedLayout titulo={frontmatter.titulo} descripcion={frontmatter.descripcion}>
  <article>
    <Text tag="h1" variant="displayMD" class="font-bold text-black tracking-tight mb-2">
      {frontmatter.titulo}
    </Text>
    <Text tag="p" variant="textSM" class="text-base-500 mb-8 border-b border-base-100 pb-4">
      Publicado el: <time datetime={frontmatter.fecha}>{frontmatter.fecha}</time>
    </Text>
    
    <Wrapper variant="prose">
      <Content />
    </Wrapper>
  </article>
</SelectedLayout>
