---
import Layout from "../layouts/Layout.astro";
import SectionCloserLook from "../components/fundations/containers/SectionCloserLook.astro";
---

<Layout title="Test Closer Look - Apple Style">
  <main class="bg-white dark:bg-black min-h-screen pt-20">
    
    {/* Variant 1: Default (Inspired by Apple Image) */}
    <SectionCloserLook 
      cardTitle="A Guided Tour of iPhone 17 Pro, iPhone Air, and iPhone 17"
      buttonText="Watch the film"
      buttonHref="#"
      imageSrc="https://media.architecturaldigest.com/photos/576c3da7a5af9f6834deb323/16:9/w_1280,c_limit/apple-store-opening-6.jpg"
    />

    <div class="h-24"></div>

    {/* Variant 2: Emerald Preset */}
    <div class="ui-closer-look-wrapper ui-preset--emerald">
      <SectionCloserLook 
        title="Expert Guidance."
        cardTitle="Navega el proceso de homologación con expertos en USA."
        buttonText="Saber más"
        buttonHref="#"
        imageSrc="https://www.apple.com/v/iphone/home/bu/images/overview/closer-look/closer_look__erf9vvjqnxue_large.jpg"
      />
    </div>

    <div class="h-24"></div>

    {/* Variant 3: Midnight Preset */}
    <div class="ui-closer-look-wrapper ui-preset--midnight">
      <SectionCloserLook 
        title="Premium Quality."
        cardTitle="Descubre la excelencia en cada detalle de tu carrera."
        buttonText="Comenzar viaje"
        buttonHref="#"
        imageSrc="https://www.apple.com/v/iphone/home/bu/images/overview/closer-look/closer_look__erf9vvjqnxue_large.jpg"
      />
    </div>

  </main>
</Layout>

<style is:global>
  /* Helper to wrap and apply preset for testing */
  .ui-closer-look-wrapper .ui-closer-look {
    @apply px-0; /* Adjust for the wrapper */
  }
</style>
