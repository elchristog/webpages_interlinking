---
import LayoutA from '../layouts/LayoutA.astro';
import SectionCloserLook from '../components/fundations/containers/SectionCloserLook.astro';
---

<LayoutA title="Test Section Closer Look" description="Verification page for the redesigned SectionCloserLook component">
  <div class="space-y-24 bg-white py-20">
    <!-- Default / Base (Gray/Orange inspired) -->
    <SectionCloserLook 
      title="Take a closer look."
      cardTitle="A Guided Tour of iPhone 17 Pro, iPhone Air, and iPhone 17"
      buttonText="Watch the film"
      buttonHref="#"
      imageSrc="https://images.unsplash.com/photo-1616348436168-de43ad0db179?q=80&w=2000&auto=format&fit=crop"
    />

    <!-- Sunset Preset -->
    <div class="ui-preset--sunset">
      <SectionCloserLook 
        title="Impacto Visual."
        cardTitle="Descubre la potencia del nuevo ecosistema Sunset"
        buttonText="Ver video"
        buttonHref="#"
        imageSrc="https://images.unsplash.com/photo-1550009158-9ebf69173e03?q=80&w=2000&auto=format&fit=crop"
      />
    </div>

    <!-- Midnight Preset -->
    <div class="ui-preset--midnight">
      <SectionCloserLook 
        title="Lujo Absoluto."
        cardTitle="Elegancia en cada píxel con Midnight Luxury"
        buttonText="Explorar ahora"
        buttonHref="#"
        imageSrc="https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?q=80&w=2000&auto=format&fit=crop"
      />
    </div>

    <!-- Emerald Preset -->
    <div class="ui-preset--emerald">
      <SectionCloserLook 
        title="Confianza Médica."
        cardTitle="Tu carrera de enfermería empieza aquí"
        buttonText="Saber más"
        buttonHref="#"
        imageSrc="https://images.unsplash.com/photo-1576091160550-217359f42f8c?q=80&w=2000&auto=format&fit=crop"
      />
    </div>
  </div>
</LayoutA>
