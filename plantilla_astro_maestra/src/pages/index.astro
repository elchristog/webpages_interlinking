---
import LayoutA from '../layouts/LayoutA.astro';
import LayoutB from '../layouts/LayoutB.astro';
import LayoutC from '../layouts/LayoutC.astro';
import config from '../data/config_inyectada.json';
import home_content from '../data/home_content.json';

const articulos = Object.values(import.meta.glob('../content/articulos/*.md', { eager: true }));

// Logic to pick layout
let SelectedLayout = LayoutA;
if (config.layout === 'LayoutB') {
  SelectedLayout = LayoutB;
} else if (config.layout === 'LayoutC') {
  SelectedLayout = LayoutC;
}
---

<SelectedLayout titulo={`${config.nombre_sitio} | Inicio`}>
    {home_content.active ? (
        <div class="custom-home">
            <h1 style="color: var(--primary-color);">{home_content.titulo}</h1>
            <div set:html={home_content.cuerpo} />
            
            <hr style="margin: 3rem 0;" />
            <h3>Últimas actualizaciones</h3>
            <ul class="article-list">
                {articulos.map((articulo: any) => (
                    <li>
                        <a href={`/blog/${articulo.frontmatter.slug}`}>
                            <h4>{articulo.frontmatter.titulo}</h4>
                        </a>
                    </li>
                ))}
            </ul>
        </div>
    ) : (
        <div class="homepage">
            <h1>Bienvenido a {config.nombre_sitio}</h1>
            <p>Aquí puedes encontrar información valiosa sobre:</p>
            
            <ul class="article-list">
                {articulos.map((articulo: any) => (
                    <li>
                        <a href={`/blog/${articulo.frontmatter.slug}`}>
                            <h2>{articulo.frontmatter.titulo}</h2>
                            <p>{articulo.frontmatter.descripcion}</p>
                        </a>
                    </li>
                ))}
            </ul>
        </div>
    )}
</SelectedLayout>

<style>
	.homepage {
		max-width: 800px;
		margin: 0 auto;
		font-family: Arial, sans-serif;
	}
	.article-list {
		list-style: none;
		padding: 0;
	}
	.article-list li {
		margin-bottom: 2rem;
		border: 1px solid #ccc;
		padding: 1rem;
		border-radius: 8px;
	}
	.article-list a {
		text-decoration: none;
		color: inherit;
	}
	.article-list h2 {
		margin: 0 0 0.5rem 0;
		color: #005b96;
	}
	.article-list p {
		margin: 0;
		color: #555;
	}
</style>
