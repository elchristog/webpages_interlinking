---
import LayoutA from '../layouts/LayoutA.astro';
import LayoutB from '../layouts/LayoutB.astro';
import LayoutC from '../layouts/LayoutC.astro';
import config from '../data/config_inyectada.json';

const articulos = Object.values(import.meta.glob('../content/articulos/*.md', { eager: true }));

// Logic to pick layout
let SelectedLayout = LayoutA;
if (config.layout === 'LayoutB') {
  SelectedLayout = LayoutB;
} else if (config.layout === 'LayoutC') {
  SelectedLayout = LayoutC;
}
---

<SelectedLayout titulo="Inicio | Red PBN">
	<div class="homepage">
		<h1>Bienvenido a la vista previa de tus Artículos</h1>
		<p>Aquí puedes previsualizar los artículos generados por la IA en la carpeta actual:</p>
		
		<ul class="article-list">
			{articulos.map((articulo: any) => (
				<li>
					<a href={`/blog/${articulo.frontmatter.slug}`}>
						<h2>{articulo.frontmatter.titulo}</h2>
						<p>{articulo.frontmatter.descripcion}</p>
					</a>
				</li>
			))}
		</ul>
	</div>
</SelectedLayout>

<style>
	.homepage {
		max-width: 800px;
		margin: 0 auto;
		font-family: Arial, sans-serif;
	}
	.article-list {
		list-style: none;
		padding: 0;
	}
	.article-list li {
		margin-bottom: 2rem;
		border: 1px solid #ccc;
		padding: 1rem;
		border-radius: 8px;
	}
	.article-list a {
		text-decoration: none;
		color: inherit;
	}
	.article-list h2 {
		margin: 0 0 0.5rem 0;
		color: #005b96;
	}
	.article-list p {
		margin: 0;
		color: #555;
	}
</style>
