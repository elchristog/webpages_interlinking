---
interface Props {
  variant?: "default" | "muted" | "accent";
  size?: "md" | "xl";
  isLink?: boolean;
  href?: string;
  class?: string;
  type?: "button" | "submit";
  id?: string;
}

const {
  variant = "default",
  size = "md",
  isLink = false,
  href = "#",
  class: className = "",
  type = "button",
  id,
} = Astro.props;

const baseStyles = "inline-flex items-center justify-center font-medium transition-colors duration-200 focus:outline-none";

const variants = {
  default: "bg-[var(--color-primary)] text-white hover:opacity-90",
  muted: "bg-base-100 text-base-900 hover:bg-base-200",
  accent: "bg-[var(--color-accent)] text-white hover:opacity-90",
};

const sizes = {
  md: "px-4 py-2 text-sm",
  xl: "px-8 py-3 text-base",
};

const combinedClasses = `${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`;
---

{
  isLink ? (
    <a href={href} class={combinedClasses} id={id}>
      <slot />
    </a>
  ) : (
    <button type={type} class={combinedClasses} id={id}>
      <slot />
    </button>
  )
}
