---
interface Card {
  category: string;
  title: string;
  subtitle: string;
  imageSrc: string;
}

interface Props {
  title?: string;
  cards?: Card[];
  preset?: string;
}

const {
  title = "Explora los detalles.",
  cards = [
    {
      category: "Innovación",
      title: "Diseño premium y duradero.",
      subtitle: "Materiales de alta calidad para una resistencia excepcional.",
      imageSrc: "https://images.unsplash.com/photo-1511707171634-5f897ff02aa9?q=80&w=800&auto=format&fit=crop"
    },
    {
      category: "Cámara",
      title: "Captura cada momento.",
      subtitle: "Tecnología de vanguardia para fotos y videos profesionales.",
      imageSrc: "https://images.unsplash.com/photo-1492724441997-5dc865305da7?q=80&w=800&auto=format&fit=crop"
    },
    {
      category: "Rendimiento",
      title: "Velocidad sin límites.",
      subtitle: "Procesadores de última generación para una experiencia fluida.",
      imageSrc: "https://images.unsplash.com/photo-1550745165-9bc0b252726f?q=80&w=800&auto=format&fit=crop"
    }
  ],
  preset = ""
} = Astro.props;
---

<section class={`ui-scrolling-cards-container ${preset}`}>
  <div class="max-w-7xl mx-auto px-0 md:px-0">
    {title && <h2>{title}</h2>}
    
    <div class="ui-scrolling-cards">
      {cards.map((card) => (
        <div class="scrolling-card">
          <img src={card.imageSrc} alt={card.title} class="card-image" />
          <div class="card-overlay">
            <div class="card-content">
              <span class="card-category">{card.category}</span>
              <h3 class="card-title">{card.title}</h3>
              <p class="card-subtitle">{card.subtitle}</p>
            </div>
          </div>
          <button class="plus-button" aria-label="Ver más">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
          </button>
        </div>
      ))}
    </div>
  </div>
</section>
