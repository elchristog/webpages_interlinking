---
interface Card {
  category?: string;
  title: string;
  description: string;
  imageSrc: string;
  link?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  cards?: Card[];
  preset?: string;
}

const {
  title = "The Apple experience.",
  subtitle = "Do even more with Apple products and services.",
  cards = [
    {
      category: "Apple Intelligence",
      title: "Apple Intelligence.",
      description: "Create, communicate, and get things done effortlessly.",
      imageSrc: "https://images.unsplash.com/photo-1611186871348-b1ce696e52c9?q=80&w=800&auto=format&fit=crop",
      link: "#"
    },
    {
      category: "Continuity",
      title: "Powerful alone.",
      description: "Superpowered together.",
      imageSrc: "https://images.unsplash.com/photo-1517336714731-489689fd1ca8?q=80&w=800&auto=format&fit=crop",
      link: "#"
    }
  ],
  preset = ""
} = Astro.props;
---

<section class={`ui-apple-experience-container ${preset}`}>
  <div class="container-wrapper">
    <div class="section-header">
      <h2 class="section-title">{title} <span class="section-subtitle">{subtitle}</span></h2>
    </div>
    <div class="apple-experience-grid">
      {cards.map((card) => (
        <div class="apple-experience-card">
          <div class="card-content">
            {card.category && <span class="card-category">{card.category}</span>}
            <h3 class="card-title">{card.title}</h3>
            <p class="card-description">{card.description}</p>
          </div>
          <div class="card-image-wrapper">
            <img src={card.imageSrc} alt={card.title} class="experience-image" />
          </div>
          {card.link && <a href={card.link} class="card-link-overlay" aria-label={`Saber más sobre ${card.title}`}></a>}
        </div>
      ))}
    </div>
  </div>
</section>
