---
interface Props {
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  backgroundImage?: string;
  logos?: string[]; // Array of image URLs or alt texts for placeholders
  class?: string;
}

const {
  title = "Marketing Digital que Genera Negocio",
  subtitle = "Agencia de Marketing Digital especializada en resultados medibles y crecimiento acelerado.",
  ctaText = "Reserva tu Consultoría Gratuita",
  ctaLink = "#",
  backgroundImage = "https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=2069&auto=format&fit=crop",
  logos = [
    "shopify", "cooltra", "danone", "enrique-tomas", "glovo", "typeform"
  ],
  class: className = "",
} = Astro.props;
---

<section class={`ui-hero-agency ${className}`} style={`--bg-image: url('${backgroundImage}')`}>
  <div class="hero-content">
    <h1 set:html={title} />
    <p class="subtitle">{subtitle}</p>
    
    <div class="hero-cta">
      <a href={ctaLink} class="btn-agency">
        {ctaText}
      </a>
    </div>

    {logos && logos.length > 0 && (
      <div class="trust-bar">
        {logos.map((logo) => (
          <img 
            src={`https://via.placeholder.com/150x50?text=${logo}`} 
            alt={`Logo ${logo}`} 
            class="trust-logo" 
          />
        ))}
      </div>
    )}
  </div>
</section>
