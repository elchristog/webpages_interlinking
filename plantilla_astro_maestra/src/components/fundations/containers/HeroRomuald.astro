---
import Text from "../elements/Text.astro";
import Button from "../elements/Button.astro";

interface Props {
  title: string;
  subtitle?: string;
  ctaText?: string;
  buttonText: string;
  buttonHref: string;
  backgroundImage: string;
  personImage?: string;
}

const {
  title,
  subtitle,
  ctaText,
  buttonText,
  buttonHref,
  backgroundImage,
  personImage,
} = Astro.props;
---

<section class="relative w-full min-h-[90vh] flex items-center overflow-hidden bg-base-950">
  {/* Background Image with Enhanced Overlay */}
  <div class="absolute inset-0 z-0">
    <img 
      src={backgroundImage} 
      alt="" 
      class="w-full h-full object-cover opacity-50"
    />
    {/* Dynamic overlays for premium feel */}
    <div class="absolute inset-0 bg-gradient-to-tr from-base-950 via-base-950/60 to-transparent"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-base-950/20 to-base-950"></div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-24 py-24 flex flex-col md:flex-row items-center gap-16">
    <div class="flex-1 text-center md:text-left">
      <div class="inline-block px-4 py-1.5 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-sm font-bold tracking-widest uppercase mb-8 animate-fade-in">
        Expert Digital Marketing
      </div>

      <Text tag="h1" variant="displayXL" class="text-white font-black mb-8 leading-[1.1] tracking-tight">
        {title.split(' ').map((word, i) => (
          i === 1 ? <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-500">{word} </span> : word + ' '
        ))}
      </Text>
      
      {subtitle && (
        <Text tag="p" variant="textLG" class="text-base-300 mb-10 max-w-2xl mx-auto md:mx-0 leading-relaxed opacity-90">
          {subtitle}
        </Text>
      )}

      <div class="space-y-8">
        {ctaText && (
          <Text tag="p" variant="textLG" class="text-base-400 font-medium tracking-wide">
            {ctaText}
          </Text>
        )}

        <div class="flex flex-col sm:flex-row items-center gap-6 justify-center md:justify-start">
          <Button isLink href={buttonHref} size="xl" variant="default" class="rounded-2xl px-12 py-5 text-lg font-bold shadow-2xl shadow-blue-500/30 hover:shadow-blue-500/50 transition-all duration-500 hover:-translate-y-1">
            {buttonText}
          </Button>
          
          <a href="#more" class="text-white hover:text-blue-400 font-semibold transition-colors flex items-center gap-2 group">
            Ver más detalles <span class="group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>
      </div>
    </div>

    {personImage && (
      <div class="flex-1 hidden lg:flex justify-end relative">
        <div class="absolute -inset-4 bg-blue-500/20 blur-3xl rounded-full animate-pulse"></div>
        <img 
          src={personImage} 
          alt="" 
          class="relative z-10 w-full max-w-lg object-contain drop-shadow-[0_35px_60px_rgba(0,0,0,0.8)] filter brightness-110"
        />
      </div>
    )}
  </div>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 0.8s ease-out forwards;
  }
</style>
