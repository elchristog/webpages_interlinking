---
import Text from "../elements/Text.astro";
import Button from "../elements/Button.astro";

interface Props {
  title?: string;
  cardTitle: string;
  buttonText: string;
  buttonHref: string;
  imageSrc: string;
}

const {
  title = "Take a closer look.",
  cardTitle,
  buttonText,
  buttonHref,
  imageSrc,
} = Astro.props;
---

<section class="ui-closer-look">
  <div class="container-wrapper">
    {title && (
      <h2 class="closer-look-heading">
        {title}
      </h2>
    )}

    <div class="closer-look-card">
      <div class="closer-look-content">
        <h3>
          {cardTitle}
        </h3>
        
        <a href={buttonHref} class="closer-look-btn">
          {buttonText}
        </a>
      </div>

      <div class="closer-look-media">
        <img 
          src={imageSrc} 
          alt={cardTitle} 
          loading="lazy"
        />
      </div>
    </div>
  </div>
</section>

