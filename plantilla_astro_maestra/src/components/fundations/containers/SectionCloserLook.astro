---
import Text from "../elements/Text.astro";
import Button from "../elements/Button.astro";

interface Props {
  title?: string;
  cardTitle: string;
  buttonText: string;
  buttonHref: string;
  imageSrc: string;
}

const {
  title = "Take a closer look.",
  cardTitle,
  buttonText,
  buttonHref,
  imageSrc,
} = Astro.props;
---

<section class="ui-closer-look py-12 md:py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    {title && (
      <Text tag="h2" variant="displayXL" class="closer-look-heading text-base-900 dark:text-white font-bold mb-12 tracking-tight">
        {title}
      </Text>
    )}

    <div class="closer-look-card relative overflow-hidden rounded-[3rem] bg-base-100 dark:bg-base-900 group">
      <div class="flex flex-col md:flex-row items-center">
        {/* Content Side */}
        <div class="closer-look-content flex-1 p-12 md:p-20 z-10 text-center md:text-left">
          <Text tag="h3" variant="displayLG" class="text-base-950 dark:text-white font-bold leading-[1.15] mb-10 max-w-md mx-auto md:mx-0">
            {cardTitle}
          </Text>
          
          <Button 
            isLink 
            href={buttonHref} 
            variant="default" 
            size="lg" 
            class="rounded-full px-8 py-3 bg-base-950 text-white hover:bg-base-900 transition-all font-medium"
          >
            {buttonText}
          </Button>
        </div>

        {/* Image Side */}
        <div class="closer-look-media flex-1 relative w-full h-full min-h-[400px] md:min-h-[600px] flex items-end justify-center overflow-hidden">
          {/* Dynamic Background Gradient mapped via CSS */}
          <div class="closer-look-bg-gradient absolute inset-0 z-0"></div>
          
          <img 
            src={imageSrc} 
            alt={cardTitle} 
            class="relative z-10 w-full h-[120%] object-cover object-bottom transition-transform duration-700 group-hover:scale-105"
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Base styles handled in global.css to allow AI injection, 
     but specific layout refinements here */
  .closer-look-bg-gradient {
    background: linear-gradient(to right, transparent 0%, rgba(0,0,0,0.05) 100%);
  }
</style>
