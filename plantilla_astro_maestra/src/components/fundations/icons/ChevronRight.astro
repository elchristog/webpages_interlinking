---
const { size = "md" } = Astro.props;

const sizes = {
  sm: "size-3",
  md: "size-4",
  lg: "size-6"
};

const sizeClass = sizes[size as keyof typeof sizes] || sizes.md;
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width="24"
  height="24"
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={sizeClass}
>
  <path d="m9 18 6-6-6-6"></path>
</svg>
