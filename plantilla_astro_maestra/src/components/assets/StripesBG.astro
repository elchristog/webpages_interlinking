---
const { class: className, variant = "base" } = Astro.props;

const variants = {
  base: "bg-base-vertical-stripes",
  accent: "bg-accent-vertical-stripes",
  light: "bg-light-vertical-stripes"
};

const variantClass = variants[variant as keyof typeof variants] || variants.base;
---
<div aria-hidden="true" class={`${variantClass} ${className}`}></div>
