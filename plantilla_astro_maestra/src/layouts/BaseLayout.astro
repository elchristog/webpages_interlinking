---
// Foundations
import "@/styles/global.css";
import BaseHead from "@/components/fundations/head/BaseHead.astro";
// Components
import Navigation from "@/components/global/Navigation.astro";
import NavigationV2 from "@/components/global/NavigationV2.astro";
import NavigationV3 from "@/components/global/NavigationV3.astro";
import Footer from "@/components/global/Footer.astro";
import FooterV2 from "@/components/global/FooterV2.astro";
import FooterV3 from "@/components/global/FooterV3.astro";
import config from "@/data/config_inyectada.json";

const { titulo, descripcion, hideNav = false, hideFooter = false } = Astro.props;
const fontName = config.font_family || "Inter";
const palette = config.color_palette || {
  primary: "#000000",
  secondary: "#4b5563",
  accent: "#2563eb",
  text_bold: "#000000"
};

const navFooterVersion = config.nav_footer_version || "v1";
let SelectedNav = Navigation;
let SelectedFooter = Footer;

if (navFooterVersion === "v2") {
  SelectedNav = NavigationV2;
  SelectedFooter = FooterV2;
} else if (navFooterVersion === "v3") {
  SelectedNav = NavigationV3;
  SelectedFooter = FooterV3;
}
---

<html lang="es" class="scroll-smooth selection:bg-secondary/20 selection:text-accent overflow-x-hidden">
  <head>
    <BaseHead titulo={titulo} descripcion={descripcion} />
    <style define:vars={{ 
      primaryRaw: palette.primary, 
      secondaryRaw: palette.secondary, 
      accentRaw: palette.accent,
      textBoldRaw: palette.text_bold,
      fontFamily: fontName
    }}>
      :root {
        --color-primary-raw: var(--primaryRaw);
        --color-secondary-raw: var(--secondaryRaw);
        --color-accent-raw: var(--accentRaw);
        --color-text-bold-raw: var(--textBoldRaw);
        --font-family: var(--fontFamily);
      }
    </style>
  </head>
  <body class="relative flex flex-col bg-white min-h-dvh overflow-x-hidden" style={`font-family: '${fontName}', sans-serif;`}>
    {!hideNav && <SelectedNav />}
    <main class="flex-grow pt-24 px-4 sm:px-6 lg:px-8"><slot /></main>
    {!hideFooter && <SelectedFooter />}
  </body>
</html>
