---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const { titulo, descripcion } = Astro.props;
---

<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8" />
    <SEO titulo_pagina={titulo} descripcion_pagina={descripcion} />
    <style is:global>
      body {
        margin: 0;
        font-family: system-ui, -apple-system, sans-serif;
        line-height: 1.5;
        color: #333;
      }
      a { color: #005b96; }
      img, iframe {
        max-width: 100%;
        height: auto;
      }
    </style>
  </head>
  <body>
    <Header />
    
    <main class="flex-grow">
      <slot />
    </main>

    <Footer />
  </body>
</html>
