---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Text from "@/components/fundations/elements/Text.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import ShareButtons from "@/components/fundations/elements/ShareButtons.astro";
import { Image } from "astro:assets";
import Cross from "@/components/assets/Cross.astro";

const { titulo, descripcion, image } = Astro.props;
---

<BaseLayout titulo={titulo} descripcion={descripcion}>
  <section class="overflow-hidden bg-base-950">
    <Wrapper variant="standard" class="pt-32 pb-12 relative">
      <div class="flex flex-col justify-between text-center text-balance">
        <div>
          <Text tag="p" variant="textXS" class="text-base-500 uppercase tracking-widest">
            Publicación Destacada
          </Text>
          <Text
            tag="h1"
            variant="displayXL"
            class="tracking-tight text-white font-display mt-8"
          >
            {titulo}
          </Text>
          <Text
            tag="p"
            variant="textBase"
            class="max-w-xl mx-auto mt-4 text-base-400"
          >
            {descripcion}
          </Text>
        </div>
      </div>
    </Wrapper>
    <div class="aspect-video p-4 bg-accent-500/10 border-y border-white/5 relative flex items-center justify-center">
       {image && (
          <Image
            width={1200}
            height={600}
            src={image.url}
            alt={image.alt || titulo}
            class="object-cover w-full h-full max-w-5xl rounded-2xl shadow-dimensional"
          />
       )}
    </div>
    <Wrapper variant="standard" class="py-12 border-t border-white/5 overflow-hidden">
      <div class="max-w-xl mx-auto relative px-4">
        <Cross class="absolute -top-[0.6rem] -right-[0.65rem] text-white/20" />
        <Cross class="absolute -top-[0.6rem] -left-[0.65rem] text-white/20" />
        <Wrapper variant="prose">
          <slot />
        </Wrapper>
        <div class="flex flex-wrap mt-12 gap-2 border-t border-white/5 pt-8">
          <Text tag="p" variant="textXS" class="text-base-500">
            Compartir artículo:
          </Text>
          <ShareButtons description={descripcion} />
        </div>
      </div>
    </Wrapper>
  </section>
</BaseLayout>
