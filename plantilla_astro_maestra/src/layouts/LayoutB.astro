---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Wrapper from "@/components/fundations/containers/Wrapper.astro";
import Text from "@/components/fundations/elements/Text.astro";

const { titulo, descripcion } = Astro.props;
---

<BaseLayout titulo={titulo} descripcion={descripcion}>
  <Wrapper variant="standard" class="py-12">
    <div class="flex flex-col lg:flex-row gap-12">
      <main class="lg:w-2/3">
        <slot />
      </main>
      
      <aside class="lg:w-1/3">
        <div class="bg-zinc-50 p-8 outline outline-base-200">
          <Text tag="h3" variant="textLG" class="font-bold text-black mb-4">📌 Enlaces Rápidos</Text>
          <ul class="space-y-3">
            <li><a href="/" class="text-zinc-600 hover:text-black transition-colors">Página Principal</a></li>
            <li><a href="/contacto" class="text-zinc-600 hover:text-black transition-colors">Contacto</a></li>
            <li><a href="/politica-de-privacidad" class="text-zinc-600 hover:text-black transition-colors">Privacidad</a></li>
          </ul>
          
          <div class="mt-8 pt-8 border-t border-base-200">
             <Text tag="p" variant="textSM" class="text-zinc-500 italic">
               Mantente actualizado con nuestras últimas guías y recursos de enfermería en USA.
             </Text>
          </div>
        </div>
      </aside>
    </div>
  </Wrapper>
</BaseLayout>
