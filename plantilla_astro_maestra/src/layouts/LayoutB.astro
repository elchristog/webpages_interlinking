---
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { titulo, descripcion } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEO titulo_pagina={titulo} descripcion_pagina={descripcion} />
  </head>
  <body>
    <Header />
    
    <div class="container" style="display: grid; grid-template-columns: 3fr 1fr; gap: 4rem; padding: 5rem 0;">
      <main style="min-height: 70vh;">
        <slot />
      </main>
      
      <aside style="border-left: 1px solid #eee; padding-left: 2rem;">
        <h4 style="margin-bottom: 2rem; color: var(--secondary-text); text-transform: uppercase; font-size: 0.8rem; letter-spacing: 0.1em;">Navegación</h4>
        <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: 1rem; font-weight: 600;">
          <li><a href="/" class="side-link">Página Principal</a></li>
          <li><a href="/contacto" class="side-link">Hablemos</a></li>
        </ul>
        
        <div style="margin-top: 4rem; padding: 2rem; background: #000; color: #fff; border-radius: 24px;">
          <h4 style="margin-bottom: 1rem;">¿Tienes dudas?</h4>
          <p style="font-size: 0.9rem; opacity: 0.8; margin-bottom: 2rem;">Nuestro equipo legal está listo para ayudarte con tu proceso migratorio.</p>
          <a href="/contacto" style="font-weight: bold; border-bottom: 2px solid #fff;">Contáctanos &rarr;</a>
        </div>
      </aside>
    </div>

    <Footer />
  </body>
</html>

<style>
  .side-link {
    transition: var(--transition);
  }
  .side-link:hover {
    padding-left: 8px;
    color: var(--secondary-text);
  }
</style>
